# Notion API 연동 필수 - 아래 값을 실제 값으로 교체하세요
NOTION_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DB_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Todo DB 고정 매핑
# 1로 두면 아래 속성명을 정확히 사용합니다. 틀리면 API가 명확한 에러를 반환합니다.
NOTION_TASK_STRICT_SCHEMA=1

# 아래 값은 당신의 Notion Todo DB 속성명과 1:1로 맞춰주세요.
NOTION_TASK_TITLE_PROP=할 일
NOTION_TASK_DATE_PROP=시작/마감

# 오늘 집중 체크박스 속성
# 스크린샷 기준으로 체크 표시된 "오늘" 컬럼은 완료가 아니라 포커스 표시입니다.
NOTION_TASK_FOCUS_PROP=오늘

# 완료 판단용 속성은 상태 속성 사용을 권장합니다.
# 즉, 실제 완료 처리는 "상태 = 완료"로 관리하는 구성을 기준으로 합니다.
# 체크박스가 진짜 완료용일 때만 NOTION_TASK_DONE_PROP를 사용하세요.
# NOTION_TASK_DONE_PROP=완료
NOTION_TASK_STATUS_PROP=상태

# 선택 속성은 있을 때만 사용합니다.
NOTION_TASK_PRIORITY_PROP=중요도
# NOTION_TASK_PROJECT_PROP=프로젝트 DB

# 상태/중요도 기본값도 실제 옵션명과 같아야 합니다.
NOTION_TASK_DEFAULT_STATUS=진행 중
NOTION_TASK_DONE_STATUS=완료
NOTION_TASK_DEFAULT_PRIORITY=중

# 프로젝트 DB 연동
# 프로젝트와 할 일을 같이 관리하려면 별도의 프로젝트 DB를 만들고,
# 할 일 DB의 relation 속성(NOTION_TASK_PROJECT_PROP)으로 프로젝트 DB를 연결하세요.
NOTION_PROJECTS_DB_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 프로젝트 DB 고정 매핑 (선택)
# 프로젝트 DB 속성명이 아래와 다르면 실제 이름으로 바꿔주세요.
NOTION_PROJECT_TITLE_PROP=프로젝트명
NOTION_PROJECT_STATUS_PROP=상태
NOTION_PROJECT_START_PROP=시작일
NOTION_PROJECT_END_PROP=마감일
NOTION_PROJECT_CLIENT_PROP=클라이언트
NOTION_PROJECT_PRIORITY_PROP=우선순위
# NOTION_PROJECT_STRICT_SCHEMA=1


# schedule 기능 (createEvent)용 - 선택이지만 schedule.html 사용 시 필수
NOTION_EVENTS_DB_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 메모 위젯 (memo.html) - 모든 기기에서 동기화하려면 필수
# Notion에서 새 DB 생성 후, 제목 컬럼 이름을 "메모"로 두거나 NOTION_MEMOS_TITLE_PROP 설정
NOTION_MEMOS_DB_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 일정 DB의 제목 속성명 (Notion 기본 "Name"이면 이 값으로 설정)
# NOTION_EVENTS_TITLE_PROP=제목

# 메모 DB의 제목 속성명 (Notion에서 메모 내용 컬럼 이름, 기본값: 메모)
# NOTION_MEMOS_TITLE_PROP=메모

# 날씨 위젯 (weather.html)을 위한 OpenWeatherMap API 키
WEATHER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
