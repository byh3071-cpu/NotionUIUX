{
  "rewrites": [
    { "source": "/embed", "destination": "/embed.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://notion.so https://www.notion.so https://*.notion.site https://*.notion.so;"
        }
      ]
    }
  ]
}
