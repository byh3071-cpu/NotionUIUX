{
  "version": 2,
  "rewrites": [
    { "source": "/embed", "destination": "/embed/calender.html" },
    { "source": "/embed/", "destination": "/embed/calender.html" }
  ],
  "headers": [
    {
      "source": "/embed/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors https://notion.so https://www.notion.so https://*.notion.site https://*.notion.so;"
        },
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    }
  ]
}
