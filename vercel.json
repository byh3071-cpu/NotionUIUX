{
  "rewrites": [
    { "source": "/", "destination": "/embed/clock.html" },
    { "source": "/clock", "destination": "/embed/clock.html" },
    { "source": "/calendar", "destination": "/embed/calendar.html" },
    { "source": "/embed/:path*", "destination": "/embed/:path*" }
  ],
  "headers": [
    {
      "source": "/embed/:path*",
      "headers": [
        { "key": "Content-Security-Policy", "value": "frame-ancestors *" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
